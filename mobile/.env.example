# Copy this file to `.env.local` and fill in your values.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the app at runtime.
#
# API base URL the app calls. On a physical phone you CANNOT use localhost —
# use your computer's LAN IP (e.g. http://192.168.1.20:8080) so the phone can
# reach the backend running on your machine. See mobile/README.md.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:8080

# Cognito user pool + app client (same values as frontend/.env.local).
EXPO_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
